From 37e20b445a0a05fa8e01678d1266d10214ed8af4 Mon Sep 17 00:00:00 2001
From: Ziyang Zhou <ziyang.zhou@outlook.com>
Date: Sun, 9 May 2021 23:04:00 +0800
Subject: [PATCH] fix build
---
diff --git a/build/Android.bp b/build/Android.bp
index 01efe67c2..c62e841f3 100644
--- a/build/Android.bp
+++ b/build/Android.bp
@@ -471,15 +471,15 @@ cvd_host_swiftshader_files = [
 genrule {
     name: "vk_lavapipe_icd.cf.json",
     srcs: [
-        ":vk_api_xml",
+        ":mesa_vulkan_xml",
     ],
     out: [
         "vk_lavapipe_icd.cf.json",
     ],
     tools: [
-        "vk_icd_py_binary",
+        "vk_icd_gen",
     ],
-    cmd: "python3 $(location vk_icd_py_binary) --api-version 1.4 --xml $(location :vk_api_xml) " +
+    cmd: "python3 $(location vk_icd_gen) --api-version 1.4 --xml $(location :mesa_vulkan_xml) " +
         "--icd-lib-path ../../../../lib64 --icd-filename vulkan.lvp.so --out $(location vk_lavapipe_icd.cf.json)",
 }
---
2.53.0
